generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Friend {
  id                   Int      @id @default(autoincrement())
  userId              Int
  friendId            Int
  status               Status     @default(PENDING)

  @@unique([userId, friendId])
}
