generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Friend {
  id                   Int      @id @default(autoincrement())
  user_id              Int
  friend_id            Int
  status               Status     @default(PENDING)

  @@unique([user_id, friend_id])
}